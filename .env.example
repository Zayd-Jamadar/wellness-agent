# Root env for docker compose. Copy to .env and fill in your key(s):
#   cp .env.example .env
#
# These are passed to the backend container (see docker-compose.yml).

# Required: used for chat completions AND KB embeddings.
OPENAI_API_KEY=

# Optional: enables the web search tool (search_web). Leave blank to disable.
TAVILY_API_KEY=

# --- Optional overrides (defaults are fine for local compose) ---
# LiteLLM model string used by the agent.
# WELLNESS_MODEL=openai/gpt-4o-mini
# Embedding model for the knowledge base.
# WELLNESS_EMBEDDING_MODEL=text-embedding-3-small
