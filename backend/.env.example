# Wellness Assistant environment configuration.
# Fill in the values you need. Only the key(s) for your chosen model are required.

# --- LLM gateway (LiteLLM) ---
# LiteLLM model string. Examples:
#   frontier: openai/gpt-4o-mini | anthropic/claude-3-5-sonnet | gemini/gemini-1.5-pro
#   OSS (direct Ollama):            ollama/qwen2.5 (with WELLNESS_API_BASE below)
#   OSS via LiteLLM proxy -> Ollama (see ../serving): openai/wellness-local
WELLNESS_MODEL=openai/gpt-4o-mini

# Optional base URL for OpenAI-compatible / self-hosted endpoints.
# Leave blank for hosted providers.
# For the OSS deployment, point at the LiteLLM proxy: http://localhost:4000
# For direct Ollama (no proxy), point at Ollama:       http://localhost:11434
WELLNESS_API_BASE=

# --- OSS serving (Ollama behind the LiteLLM proxy; see ../serving) ---
# Read by serving/litellm/config.yaml when running the proxy. Not used by the
# app directly (the app only needs WELLNESS_MODEL / WELLNESS_API_BASE above).
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# Optional generation controls.
WELLNESS_TEMPERATURE=0.3
WELLNESS_MAX_TOKENS=1024

# --- Provider API keys (set the one matching WELLNESS_MODEL) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Web search tool (search_web) ---
TAVILY_API_KEY=

# --- KB / embeddings ---
# Embeddings use the OpenAI API directly; requires OPENAI_API_KEY above.
WELLNESS_EMBEDDING_MODEL=text-embedding-3-small
WELLNESS_KB_TOP_K=4
WELLNESS_WEB_MAX_RESULTS=5
