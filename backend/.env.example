# Wellness Assistant environment configuration.
# Fill in the values you need. Only the key(s) for your chosen model are required.

# --- LLM provider routing ---
# Which chat backend to use: 'openai' (hosted) or 'ollama' (local).
WELLNESS_PROVIDER=openai

# Bare model name for the selected provider (no provider prefix). Examples:
#   openai: gpt-4o-mini
#   ollama: qwen2.5
WELLNESS_MODEL=gpt-4o-mini

# Optional base URL.
#   ollama: defaults to http://localhost:11434 when blank.
#   openai: leave blank unless using an OpenAI-compatible endpoint.
WELLNESS_API_BASE=

# Ollama thinking/reasoning mode. Off by default for clean answers and reliable
# tool calls; set true to re-enable the reasoning trace.
WELLNESS_REASONING=false

# Optional generation controls.
WELLNESS_TEMPERATURE=0.3
WELLNESS_MAX_TOKENS=1024

# --- Provider API keys ---
# OPENAI_API_KEY is required for chat when WELLNESS_PROVIDER=openai, and ALWAYS
# required for KB embeddings regardless of provider.
OPENAI_API_KEY=

# --- Web search tool (search_web) ---
TAVILY_API_KEY=

# --- KB / embeddings ---
# Embeddings use the OpenAI API directly; requires OPENAI_API_KEY above.
WELLNESS_EMBEDDING_MODEL=text-embedding-3-small
WELLNESS_KB_TOP_K=4
WELLNESS_WEB_MAX_RESULTS=5
